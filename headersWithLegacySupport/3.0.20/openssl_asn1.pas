  CHARTYPE_PRINTABLESTRING = $10;
  { Character needs escaping if it is the first character }
  CHARTYPE_FIRST_ESC_2253 = $20;
  { Character needs escaping if it is the last character }
  CHARTYPE_LAST_ESC_2253 = $40;
  
